# Copy this file to ".env" and fill in real values. ".env" is gitignored.

# Django secret key (any long random string for local dev).
SECRET_KEY=dev-insecure-change-me

# Debug mode: 1 for local development, 0 in production.
DEBUG=1

# Neon Postgres connection string.
# Get it from: Neon dashboard -> your project -> "Connection string".
# It looks like:
#   postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
# If DATABASE_URL is left unset, the app falls back to a local sqlite file
# (handy for offline development), but the real project uses Neon.
DATABASE_URL=
